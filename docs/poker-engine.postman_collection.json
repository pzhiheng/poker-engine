{
  "info": {
    "name": "Poker Engine API",
    "description": "Complete API collection for the poker-engine demo.\n\n**Quick start**\n1. Run the stack: `docker compose up --build`\n2. Run the \"00 · Setup\" folder to register players, create a table, and start a hand.\n3. Use the JWT stored in `{{token}}` (set automatically by the login request) for all authenticated requests.\n\nAll environment variables (`{{base_url}}`, `{{token}}`, `{{table_id}}`, `{{hand_id}}`, `{{alice_id}}`, `{{bob_id}}`) are populated automatically as you run the requests in order.",
    "_postman_id": "poker-engine-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",  "value": "http://localhost:8080", "type": "string" },
    { "key": "token",     "value": "", "type": "string" },
    { "key": "table_id",  "value": "", "type": "string" },
    { "key": "hand_id",   "value": "", "type": "string" },
    { "key": "alice_id",  "value": "", "type": "string" },
    { "key": "bob_id",    "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "00 · Setup",
      "description": "Register two players, create a table, seat both, and start a hand. Run these in order — each request saves IDs to collection variables.",
      "item": [
        {
          "name": "Register alice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('token',    r.token);",
                  "pm.collectionVariables.set('alice_id', r.playerId);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"alice\",\"password\":\"alice1234\"}"
            }
          }
        },
        {
          "name": "Register bob",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('bob_id', r.playerId);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"bob\",\"password\":\"bob12345\"}"
            }
          }
        },
        {
          "name": "Login alice (refresh token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('token', r.token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"alice\",\"password\":\"alice1234\"}"
            }
          }
        },
        {
          "name": "Create table (5/10 blinds)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('table_id', r.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status WAITING', () => pm.expect(r.status).to.eql('WAITING'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Demo Table\",\"smallBlind\":5,\"bigBlind\":10}"
            }
          }
        },
        {
          "name": "Seat alice (seat 1)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables/{{table_id}}/seats",
            "body": {
              "mode": "raw",
              "raw": "{\"playerId\":\"{{alice_id}}\",\"seatNo\":1,\"buyIn\":500}"
            }
          }
        },
        {
          "name": "Seat bob (seat 2)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/tables/{{table_id}}/seats",
            "body": {
              "mode": "raw",
              "raw": "{\"playerId\":\"{{bob_id}}\",\"seatNo\":2,\"buyIn\":500}"
            }
          }
        },
        {
          "name": "Start hand",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.collectionVariables.set('hand_id', r.handId);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Street is PREFLOP', () => pm.expect(r.street).to.eql('PREFLOP'));",
                  "pm.test('Has hole cards', () => pm.expect(r.myHoleCards).to.have.lengthOf(2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tables/{{table_id}}/hands"
          }
        }
      ]
    },
    {
      "name": "01 · Tables",
      "item": [
        {
          "name": "List all tables",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tables"
          }
        },
        {
          "name": "List WAITING tables",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tables?status=WAITING",
              "host": ["{{base_url}}"],
              "path": ["tables"],
              "query": [{ "key": "status", "value": "WAITING" }]
            }
          }
        },
        {
          "name": "Get table detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tables/{{table_id}}"
          }
        }
      ]
    },
    {
      "name": "02 · Actions (coaching feedback)",
      "description": "Record player actions and observe the live coaching feedback in the response.",
      "item": [
        {
          "name": "Action — CALL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.test('Has feedback', () => pm.expect(r.feedback).to.not.be.null);",
                  "pm.test('Has equity', () => pm.expect(r.feedback.equity).to.be.within(0, 1));",
                  "pm.test('Has explanation', () => pm.expect(r.feedback.explanation).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/hands/{{hand_id}}/actions",
            "body": {
              "mode": "raw",
              "raw": "{\"actionType\":\"CALL\",\"amount\":5}"
            }
          }
        },
        {
          "name": "Action — CHECK",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/hands/{{hand_id}}/actions",
            "body": {
              "mode": "raw",
              "raw": "{\"actionType\":\"CHECK\",\"amount\":0}"
            }
          }
        },
        {
          "name": "Action — FOLD",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/hands/{{hand_id}}/actions",
            "body": {
              "mode": "raw",
              "raw": "{\"actionType\":\"FOLD\",\"amount\":0}"
            }
          }
        },
        {
          "name": "Action — RAISE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/hands/{{hand_id}}/actions",
            "body": {
              "mode": "raw",
              "raw": "{\"actionType\":\"RAISE\",\"amount\":30}"
            }
          }
        }
      ]
    },
    {
      "name": "03 · Analytics",
      "item": [
        {
          "name": "Get alice's stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/players/{{alice_id}}/stats"
          }
        },
        {
          "name": "Get alice's coaching profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/players/{{alice_id}}/profile"
          }
        }
      ]
    },
    {
      "name": "04 · Import",
      "item": [
        {
          "name": "List import jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/import/hands"
          }
        }
      ]
    },
    {
      "name": "05 · Observability",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/health"
          }
        },
        {
          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/actuator/prometheus"
          }
        },
        {
          "name": "OpenAPI spec (JSON)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v3/api-docs"
          }
        },
        {
          "name": "go-odds health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/health"
          }
        },
        {
          "name": "go-odds Prometheus metrics",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/metrics"
          }
        }
      ]
    }
  ]
}
